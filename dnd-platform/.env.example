# Supabase — get these from your project's Settings → API page
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq — https://console.groq.com → API Keys
GROQ_API_KEY=

# Anthropic — optional, used for summarisation and DM co-pilot fallback
ANTHROPIC_API_KEY=

# Upstash Redis — rate limiting (required in production)
# Get from https://console.upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error monitoring (required in production)
# Get from https://sentry.io → Settings → Projects → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
